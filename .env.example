# =====================================================================
# Required — Google OAuth + allowed user
# =====================================================================
# Create a Google OAuth client at https://console.cloud.google.com/apis/credentials
# Set the redirect URI to: https://<your-domain>/auth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Only this email will be able to sign in. Single-user by design.
ALLOWED_EMAIL=you@gmail.com

# =====================================================================
# Required — Claude Code (task delegation, knowledge ingest skills)
# =====================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =====================================================================
# Required — Voice agent (STT, planner, TTS)
# =====================================================================
OPENAI_API_KEY=sk-...
# Optional overrides. Defaults shown.
# VOICE_LLM_MODEL=gpt-5.4
# VOICE_STT_MODEL=gpt-4o-transcribe
# semantic_vad eagerness: low | medium | high | auto
# Lower = more pause tolerance before the agent decides you're done speaking.
# VOICE_STT_EAGERNESS=low
# VOICE_TTS_MODEL=gpt-4o-mini-tts
# VOICE_TTS_VOICE=coral
# VOICE_TTS_SPEED=1.15

# =====================================================================
# Optional — Git-synced notes vault
# =====================================================================
# Point at any git repo containing a vault of .md files (Obsidian-compatible).
# The server clones on boot, auto-pulls every NOTES_SYNC_INTERVAL seconds, and
# surfaces a GitHub-style diff review UI for pushes.
# NOTES_REPO=https://github.com/your-user/obsidian-vault.git
# GITHUB_TOKEN=ghp_...
# NOTES_SYNC_INTERVAL=300
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com

# =====================================================================
# General
# =====================================================================
WORKSPACE_DIR=/workspace
PORT=3000
# Session cookie signer. Auto-generated per boot if omitted — set this if you
# want sessions to survive server restarts.
# SESSION_SECRET=some-random-string

# =====================================================================
# Railway-specific (set automatically by Railway; override if needed)
# =====================================================================
# RAILWAY_RUN_UID=0
